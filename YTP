-- [[ 1. THE PERSISTENCE ENGINE ]]
local raw_url = "https://raw.githubusercontent.com/buckyport/YTP/refs/heads/main/YTP"
local queue_on_teleport = (queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport))

if queue_on_teleport then
    pcall(function()
        queue_on_teleport('loadstring(game:HttpGet("' .. raw_url .. '"))()')
    end)
end

-- Wait for game load
if not game:IsLoaded() then 
    warn("BUCKSHOT: Waiting for game engine to load...")
    game.Loaded:Wait() 
end

local player = game.Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")
local VIM = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local RS = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")
local camera = workspace.CurrentCamera

print("-----------------------------------------")
print("BUCKSHOT DIAGNOSTIC LOADED: " .. os.date("%X"))
print("-----------------------------------------")

-- [[ 2. THE REPEATABLE CORE ]]
local function startTurbo()
    -- STAGE 1: THE MENU CHECK
    print("LOG: Checking for TitleScreen...")
    local titleScreen = pGui:WaitForChild("TitleScreen", 15)
    
    if titleScreen then
        print("LOG: TitleScreen object found. Status: " .. tostring(titleScreen.Enabled))
        local clickCount = 0
        while titleScreen.Enabled do
            local playBtn = titleScreen:FindFirstChild("PlayButton")
            if playBtn then
                clickCount = clickCount + 1
                if clickCount % 5 == 0 then print("LOG: Still clicking Play... (Attempt " .. clickCount .. ")") end
                
                local pos = playBtn.AbsolutePosition
                local size = playBtn.AbsoluteSize
                VIM:SendMouseButtonEvent(pos.X + (size.X/2), pos.Y + (size.Y/2) + 36, 0, true, game, 1)
                task.wait(0.01)
                VIM:SendMouseButtonEvent(pos.X + (size.X/2), pos.Y + (size.Y/2) + 36, 0, false, game, 1)
                
                GuiService.SelectedObject = playBtn
                VIM:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            else
                warn("ERROR: TitleScreen exists but PlayButton is MISSING!")
            end
            task.wait(0.5)
        end
        print("LOG: TitleScreen successfully cleared.")
    else
        warn("LOG: TitleScreen not found after 15s. Skipping to spawn check.")
    end

    -- STAGE 2: THE SPAWN CHECK
    print("LOG: Waiting for Character Spawning...")
    local char = player.Character or player.CharacterAdded:Wait()
    print("LOG: Character detected. Waiting for RootPart...")
    local root = char:WaitForChild("HumanoidRootPart", 10)
    
    if not root then
        warn("ERROR: HumanoidRootPart never appeared! Script may fail.")
        return
    end
    
    print("LOG: Character is physically ready. Waiting 2s for DataLoadScreen safety...")
    task.wait(2)

    -- STAGE 3: THE COLLECTION LOOP
    print("LOG: Beginning YTP Scan...")
    local function collect()
        local items = {}
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name:find("YTP") and (v:IsA("Model") or v:IsA("BasePart")) then
                table.insert(items, v)
            end
        end
        
        print("LOG: Found " .. #items .. " potential YTP items.")
        
        if #items == 0 then return false end

        for i, item in ipairs(items) do
            print("LOG: Collecting Item " .. i .. " [" .. item.Name .. "]")
            local target = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
            
            if target and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local currentRoot = player.Character.HumanoidRootPart
                currentRoot.CFrame = target.CFrame
                currentRoot.Anchored = true
                
                local s = tick()
                while item.Parent and (tick() - s) < 1.0 do
                    local cd = item:FindFirstChildWhichIsA("ClickDetector", true)
                    if cd then fireclickdetector(cd) end
                    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(0.05)
                end
                currentRoot.Anchored = false
            else
                warn("LOG: Target or Root lost while collecting item " .. i)
            end
        end
        return true
    end

    local success = collect()
    
    -- STAGE 4: SERVER HOP
    if not success then
        warn("LOG: No YTPs found in workspace. Preparing to hop.")
    else
        print("LOG: Map cleared. Preparing to hop.")
    end
    
    task.wait(1)
    print("LOG: Fetching server list...")
    
    local hopSuccess, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
    end)
    
    if hopSuccess and result then
        local data = game:GetService("HttpService"):JSONDecode(result).data
        for _, v in ipairs(data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                print("LOG: Teleporting to new server: " .. v.id)
                TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id)
                return
            end
        end
    else
        warn("ERROR: Failed to fetch server list. Retrying in 5s.")
        task.wait(5)
        startTurbo() -- Recursive retry
    end
end

-- Start the Diagnostic
task.spawn(startTurbo)
