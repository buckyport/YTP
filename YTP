-- [[ 1. THE PERSISTENCE ENGINE ]]
local raw_url = "https://raw.githubusercontent.com/buckyport/YTP/refs/heads/main/YTP"
local queue_on_teleport = (queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport))

if queue_on_teleport then
    pcall(function()
        queue_on_teleport('loadstring(game:HttpGet("' .. raw_url .. '"))()')
    end)
end

-- Wait for the engine to actually put you in a server
if not game:IsLoaded() then game.Loaded:Wait() end

local player = game.Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")
local VIM = game:GetService("VirtualInputManager")
local TeleportService = game:GetService("TeleportService")
local RS = game:GetService("RunService")
local camera = workspace.CurrentCamera

-- [[ 2. THE MENU-GATE BYPASS ]]
local function clearMenus()
    print("F9 LOG: Attempting Menu Bypass...")
    
    -- 1. Ensure the TitleScreen is actually there before trying anything
    local title = pGui:WaitForChild("TitleScreen", 30)
    local btn = title and title:FindFirstChild("PlayButton")
    
    if title and btn then
        local pos = btn.AbsolutePosition
        local size = btn.AbsoluteSize
        local clickX, clickY = pos.X + (size.X/2), pos.Y + (size.Y/2) + 36
        
        -- 2. AGGRESSIVE CLICKING: Keep clicking until the button is no longer visible
        local clickTimeout = tick()
        while btn.Visible and (tick() - clickTimeout) < 15 do
            VIM:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
            task.wait(0.05)
            VIM:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
            
            print("F9 LOG: Clicking Play... waiting for menu to disappear.")
            task.wait(0.5) 
        end
        
        -- 3. THE "STUCK" CHECK: Wait specifically for the TitleScreen to be gone
        local uiClearWait = tick()
        while title.Parent == pGui and (tick() - uiClearWait) < 10 do
            task.wait(0.5)
            print("F9 LOG: Menu still mounted. Waiting...")
        end
    end
end

-- [[ 3. TURBO SERVER HOP ]]
local function serverHop()
    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
    end)
    if success and result then
        local data = game:GetService("HttpService"):JSONDecode(result).data
        local possibleServers = {}
        for _, v in ipairs(data) do
            if v.playing and v.maxPlayers and v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(possibleServers, v.id)
            end
        end
        if #possibleServers > 0 then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, possibleServers[math.random(1, #possibleServers)])
        end
    end
end

-- [[ 4. THE CLEAN SWEEP ENGINE ]]
local function runTurbo()
    -- BLOCK 1: Clear Menu
    clearMenus()

    -- BLOCK 2: Wait for Character + Physics stability
    print("F9 LOG: Waiting for physical spawn...")
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart", 20)
    
    -- Extra 3 seconds to ensure the game has finished loading the map and character type
    task.wait(3) 

    print("F9 LOG: Physics synced. Scanning for YTP...")
    local items = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name:find("YTP") or v.Name:find("YTP_")) and (v:IsA("Model") or v:IsA("BasePart")) then
            table.insert(items, v)
        end
    end

    if #items == 0 then 
        print("F9 LOG: Server empty. Hopping.")
        serverHop() 
        return 
    end

    -- BLOCK 3: Collection
    for _, item in ipairs(items) do
        local hitbox = item:FindFirstChild("InteractionHitbox") or item:FindFirstChildWhichIsA("BasePart", true) or (item:IsA("BasePart") and item)
        
        if hitbox and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            hrp.CFrame = hitbox.CFrame * CFrame.new(0, 0, 2.5) 
            hrp.Anchored = true
            
            local camLock = RS.RenderStepped:Connect(function()
                if hitbox and hitbox.Parent then
                    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, hitbox.Position)
                end
            end)
            
            local clickStart = tick()
            while item.Parent and (tick() - clickStart) < 1.5 do
                local cd = item:FindFirstChildWhichIsA("ClickDetector", true)
                if cd then fireclickdetector(cd) end
                
                local center = camera.ViewportSize / 2
                VIM:SendMouseButtonEvent(center.X, center.Y + 36, 0, true, game, 1)
                task.wait(0.01)
                VIM:SendMouseButtonEvent(center.X, center.Y + 36, 0, false, game, 1)
                
                VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.05)
            end
            camLock:Disconnect()
            hrp.Anchored = false
        end
    end
    
    serverHop()
end

task.spawn(runTurbo)
