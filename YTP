task.spawn(function()
    while true do
        RS.Heartbeat:Wait()
        
     
        if _G.AutoRunOnHop then
            local mainGui = pGui:FindFirstChild("Main")
            if mainGui then
                for _, v in pairs(mainGui:GetDescendants()) do
                    if v:IsA("TextButton") and v.Visible and (v.Name:find("Play") or v.Text:find("Play")) then
                        GuiService.SelectedObject = v
                        VIM:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                        task.wait(0.05)
                        VIM:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                    end
                end
            end
        end

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if _G.AutoFarmEnabled and root then
            local items = {}
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name:find("YTP_") and (v:IsA("Model") or v:IsA("BasePart")) then
                    table.insert(items, v)
                end
            end
            
            if #items > 0 then
                for _, item in pairs(items) do
                    if not _G.AutoFarmEnabled then break end
                    local hitbox = item:FindFirstChild("InteractionHitbox") or item:FindFirstChildWhichIsA("BasePart")
                    
                    if hitbox and hitbox.Parent then
                        root.CFrame = hitbox.CFrame
                        root.Anchored = true 
                        
                        local camLock = RS.RenderStepped:Connect(function()
                            if hitbox and hitbox.Parent then
                                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, hitbox.Position + Vector3.new(0, 1, 0))
                            end
                        end)

                        local clickStart = tick()
                        while item.Parent and (tick() - clickStart) < 1.0 do
                            local cd = item:FindFirstChildWhichIsA("ClickDetector", true)
                            if cd then fireclickdetector(cd) end
                            
                            VIM:SendMouseButtonEvent(camera.ViewportSize.X/2, camera.ViewportSize.Y/2, 0, true, game, 1)
                            VIM:SendMouseButtonEvent(camera.ViewportSize.X/2, camera.ViewportSize.Y/2, 0, false, game, 1)
                            task.wait() 
                        end

                        camLock:Disconnect()
                        root.Anchored = false 
                    end
                end
            else
                serverHop()
                task.wait(2) 
            end
        end
    end
end)
